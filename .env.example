# Banco de dados PostgreSQL
DATABASE_URL=postgres://user:password@host:port/database

# Power BI — chave pública do relatório e ID do modelo
POWERBI_RESOURCE_KEY=your-resource-key-here
POWERBI_MODEL_ID=your-model-id-here

# Porta da API (padrão: 3001)
PORT=3001

# CORS — origens permitidas separadas por vírgula (deixe em branco para permitir tudo)
ALLOWED_ORIGINS=http://localhost:3000

# URL da API usada pelo collector (padrão: http://localhost:3001)
API_URL=http://localhost:3001

# URL da API usada pelo frontend Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001
