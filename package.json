{
  "name": "ccee",
  "version": "1.0.0",
  "description": "Sistema CCEE Inteligente",
  "scripts": {
    "api": "node api/index.js",
    "collector": "node collector/collector.js",
    "db:init": "node db/init.js",
    "db:migrate-geracao": "node db/migrate-geracao.js",
    "db:migrate-usinas": "node db/migrate-usinas.js",
    "web": "next dev",
    "build:web": "next build",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000,
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/pages/",
      "/db/"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "next": "14.0.0",
    "node-fetch": "^2.6.7",
    "pg": "^8.11.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recharts": "^2.6.2"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
